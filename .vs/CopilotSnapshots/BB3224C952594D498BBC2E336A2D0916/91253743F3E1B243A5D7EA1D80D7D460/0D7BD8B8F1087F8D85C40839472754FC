        /// <summary>
        /// Cáº­p nháº­t tráº¡ng thÃ¡i chá»— Ä‘á»— vá»›i validation & logging
        /// UC005.2 - Main flow
        /// </summary>
        public async Task<ServiceResult<string>> UpdateStatusAsync(UpdateSlotStatusDto dto, string employeeId)
        {
            try
            {
                // Validate input
                var inputValidation = _validator.ValidateUpdateSlotStatus(dto);
                if (!inputValidation.IsValid)
                    return ServiceResult<string>.Fail(inputValidation.ErrorMessage!);

                // Láº¥y chá»— Ä‘á»— hiá»‡n táº¡i
                var slot = await _slotRepo.GetByIdAsync(dto.SlotId);
                if (slot == null)
                    return ServiceResult<string>.Fail($"KhÃ´ng tÃ¬m tháº¥y chá»— Ä‘á»— {dto.SlotId}");

                // Validate transition
                var transitionValidation = _validator.ValidateStatusTransition(slot.Status, dto.NewStatus);
                if (!transitionValidation.IsValid)
                    return ServiceResult<string>.Fail(transitionValidation.ErrorMessage!);

                // Kiá»ƒm tra náº¿u váº«n cÃ²n xe Ä‘ang Ä‘á»— (status = "Äang sá»­ dá»¥ng")
                if (slot.Status == "Äang sá»­ dá»¥ng" && (dto.NewStatus == "Báº£o trÃ¬" || dto.NewStatus == "Há»ng"))
                {
                    // Kiá»ƒm tra cÃ³ ticket active khÃ´ng
                    var activeTicket = await _ticketRepo.GetActiveByPlateAsync(dto.SlotId);
                    if (activeTicket != null)
                        return ServiceResult<string>.Fail(
                            "KhÃ´ng thá»ƒ cáº­p nháº­t tráº¡ng thÃ¡i nÃ y vÃ¬ váº«n cÃ²n xe Ä‘ang Ä‘á»—. Vui lÃ²ng kiá»ƒm tra láº¡i checkout hoáº·c xe.");
                }

                // Validate ghi chÃº (náº¿u cáº§n)
                var noteValidation = _validator.ValidateNote(dto.Note, dto.NewStatus);
                if (!noteValidation.IsValid)
                    return ServiceResult<string>.Fail(noteValidation.ErrorMessage!);

                // Cáº­p nháº­t slot status
                slot.Status = dto.NewStatus;
                slot.LastUpdated = DateTime.Now;
                await _slotRepo.UpdateAsync(slot);

                // Ghi log láº¡i thay Ä‘á»•i
                var logId = await _auditRepo.GenerateIdAsync();
                var auditLog = new ParkingSlotAuditLog
                {
                    LogId = logId,
                    SlotId = dto.SlotId,
                    EmployeeId = employeeId,
                    OldStatus = slot.Status,  // Note: giÃ¡ trá»‹ cÅ© Ä‘Ã£ Ä‘Æ°á»£c set lÃºc validate
                    NewStatus = dto.NewStatus,
                    Note = dto.Note,
                    ChangedAt = DateTime.Now,
                    Reason = $"Cáº­p nháº­t báº±ng tay bá»Ÿi nhÃ¢n viÃªn {employeeId}"
                };
                await _auditRepo.AddAsync(auditLog);

                // Return success message
                return ServiceResult<string>.Ok(
                    logId,
                    $"Cáº­p nháº­t tráº¡ng thÃ¡i chá»— {dto.SlotId} thÃ nh '{dto.NewStatus}' thÃ nh cÃ´ng.");
            }
            catch (Exception ex)
            {
                return ServiceResult<string>.Fail($"Lá»—i cáº­p nháº­t tráº¡ng thÃ¡i: {ex.Message}");
            }
        }

